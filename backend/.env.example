# Variables d'environnement — copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le fichier .env !

# Cle API Gemini (Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Cle API OpenAI (optionnel)
OPENAI_API_KEY=your_openai_api_key_here

# Secret de session (chaine aleatoire)
SESSION_SECRET=change_this_to_a_random_string

# Port (Render utilise automatiquement process.env.PORT)
PORT=3000